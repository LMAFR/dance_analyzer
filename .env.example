# Copy to .env and adjust. Used by docker-compose.

# Port the web (Caddy) container publishes for HTTP. Put this behind your
# existing reverse proxy, or expose it directly.
HTTP_PORT=8090

# Caddy listener. ":80" = plain HTTP (default). Set to a domain you control
# (e.g. dance.example.com) to get automatic Let's Encrypt HTTPS — then also
# publish port 443 in docker-compose.yml.
SITE_ADDRESS=:80

# Upload limits enforced by the backend.
MAX_MB=200
MAX_SECS=600

# Tracks are ephemeral. Keep at most this many, and auto-delete any older than
# the TTL (seconds). 10800 = 3h. The frontend also deletes a track when you hit
# "New video". Set TTL to 0 to disable time-based deletion.
MAX_TRACKS=40
TRACK_TTL=10800

# CORS. "*" is fine when the frontend is served from the same origin (Caddy).
ALLOWED_ORIGINS=*
